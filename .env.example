# --- API ---
API_PORT=4000
NODE_ENV=development

# --- Database (SQLite file path; use ":memory:" for ephemeral/test runs) ---
DATABASE_URL=./data/dev.sqlite

# --- Auth ---
JWT_SECRET=replace_with_secret
SESSION_SECRET=replace_with_secret

# --- ERP integration (placeholder) ---
ERP_API_BASE_URL=https://erp.example.internal
ERP_API_KEY=replace_with_key

# --- AI listing generation (placeholder) ---
AI_PROVIDER_API_KEY=replace_with_key

# --- Social login (future) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# --- Storefront / Admin public config ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# Sprint 11 marketplace publishing (generate a 32-byte base64 key; do not commit real secrets)
MARKETPLACE_CREDENTIAL_ENCRYPTION_KEY=
MARKETPLACE_OAUTH_STATE_SECRET=
MARKETPLACE_REQUEST_TIMEOUT_MS=10000
MARKETPLACE_PUBLISH_MAX_RETRIES=3
EBAY_API_BASE_URL=https://api.ebay.com
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_REDIRECT_URI=
ETSY_API_BASE_URL=https://api.etsy.com
ETSY_CLIENT_ID=
ETSY_CLIENT_SECRET=
ETSY_REDIRECT_URI=
