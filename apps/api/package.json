{
  "name": "@noctella/api",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json && cp src/db/schema.sql dist/db/schema.sql",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:parity": "tsx src/scripts/dbParity.ts",
    "db:migration-preview": "tsx src/scripts/dbMigrationPreview.ts",
    "db:integrity": "tsx src/scripts/dbIntegrity.ts",
    "db:backup-check": "tsx src/scripts/dbBackupCheck.ts",
    "architecture:audit": "tsx src/scripts/architectureAudit.ts",
    "repo:parity": "tsx src/scripts/productReadRepositoryAudit.ts && tsx src/scripts/productWriteRepositoryAudit.ts"
  },
  "dependencies": {
    "@noctella/shared": "0.1.0",
    "@types/multer": "^2.2.0",
    "@types/pg": "^8.20.0",
    "better-sqlite3": "^12.11.1",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.45.2",
    "express": "^4.19.2",
    "multer": "^2.0.2",
    "pg": "^8.22.0",
    "sharp": "^0.34.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.14.11",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4",
    "vitest": "^4.1.10"
  }
}
